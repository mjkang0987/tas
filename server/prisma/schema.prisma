generator client {
  provider            = "prisma-client"
  output              = "../../client/prisma/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                     String               @id @default(cuid())
  name                   String
  // 공개 예약 페이지 다국어(오너 입력, {en?,ja?,zh?}). 없으면 name 폴백.
  nameI18nJson           Json?
  shopType               String?
  onboarded              Boolean              @default(false)
  usePointSystem         Boolean              @default(false)
  useMembershipSystem    Boolean              @default(false)
  useCouponSystem        Boolean              @default(false)
  useOnlineBooking       Boolean              @default(false)
  bookingSlug            String?              @unique
  categoryBaseColorsJson Json                 @default("{}")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  customers              Customer[]
  assignees              Assignee[]
  gmailConnection        GmailConnection?
  invites                Invite[]
  memberships            Membership[]
  reservations           Reservation[]
  reservationEvents      ReservationHistory[]
  services               Service[]
  businessHours          StoreBusinessHour[]
  closedDates            StoreClosedDate[]
  pointSettings          StorePointSettings?
  bookingSettings        StoreBookingSettings?
  membershipProducts     MembershipProduct[]
  customerMemberships    CustomerMembership[]
  couponProducts         CouponProduct[]
  customerCoupons        CustomerCoupon[]
  storeNotices           StoreNotice[]
}

model User {
  id                 String            @id @default(cuid())
  email              String?           @unique
  nickname           String            @unique
  name               String?
  image              String?
  agreedTermsVersion String?
  agreedTermsAt      DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  accounts           AuthAccount[]
  invitesUsed        Invite[]          @relation("InviteUsedBy")
  invitesCreated     Invite[]          @relation("InviteCreatedBy")
  memberships        Membership[]
  gmailConnections   GmailConnection[] @relation("GmailConnectionConnectedBy")
}

model GmailConnection {
  id                String    @id @default(cuid())
  storeId           String    @unique
  connectedByUserId String?
  email             String
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  store             Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  connectedBy       User?     @relation("GmailConnectionConnectedBy", fields: [connectedByUserId], references: [id], onDelete: SetNull)
}

model AuthAccount {
  id             String    @id @default(cuid())
  userId         String
  provider       String
  providerSub    String
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([provider, providerSub])
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  storeId   String
  role      MembershipRole
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Customer {
  id             String                 @id @default(cuid())
  legacyId       Int?
  storeId        String
  name           String
  tel            String
  points         Int                    @default(0)
  firstVisitDate DateTime?
  allergyNote    String?
  claimNote      String?
  preferenceNote String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  memoTags       CustomerMemoTag[]
  pointHistories CustomerPointHistory[]
  reservations   Reservation[]
  memberships    CustomerMembership[]
  coupons        CustomerCoupon[]

  @@unique([storeId, legacyId])
  @@index([storeId, name])
  @@index([storeId, tel])
}

model CustomerMemoTag {
  id         String   @id @default(cuid())
  customerId String
  text       String
  color      String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerPointHistory {
  id                   String           @id @default(cuid())
  customerId           String
  type                 PointHistoryType
  delta                Int
  balance              Int
  description          String
  relatedReservationId String?
  createdAt            DateTime         @default(now())
  customer             Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  relatedReservation   Reservation?     @relation(fields: [relatedReservationId], references: [id])
}

model Assignee {
  id           String             @id @default(cuid())
  legacyId     Int?
  storeId      String
  name         String
  // 공개 예약 페이지 다국어(오너 입력, {en?,ja?,zh?}). 없으면 name 폴백.
  nameI18nJson Json?
  status       AssigneeStatus     @default(active)
  phone        String?
  note         String?
  color        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  schedules    AssigneeSchedule[]
  reservations Reservation[]

  @@unique([storeId, legacyId])
}

model AssigneeSchedule {
  id         String   @id @default(cuid())
  assigneeId String
  dayIndex   Int
  enabled    Boolean
  startTime  String
  endTime    String
  assignee   Assignee @relation(fields: [assigneeId], references: [id], onDelete: Cascade)

  @@unique([assigneeId, dayIndex])
}

model Service {
  id                 String                     @id @default(cuid())
  legacyName         String?
  storeId            String
  name               String
  // 공개 예약 페이지 다국어(오너 입력, {en?,ja?,zh?}). 없으면 name(한국어) 폴백. 식별은 항상 name.
  nameI18nJson       Json?
  category           String
  duration           Int
  price              Int
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  store              Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  membershipProducts MembershipProductService[]

  @@unique([storeId, name])
}

model Reservation {
  id               String                    @id @default(cuid())
  legacyId         Int?
  storeId          String
  customerId       String
  assigneeId       String?
  date             DateTime
  startTime        String
  endTime          String
  serviceSummary   String
  status           ReservationStatus         @default(active)
  price            Int                       @default(0)
  memo             String?
  paymentCompleted Boolean                   @default(false)
  pointEarned      Int                       @default(0)
  naverBookingId   String?
  naverBookingUrl  String?
  naverDeposit     Int?
  channel          ReservationChannel        @default(phone)
  publicToken      String?                   @unique
  pendingAction    ReservationPendingAction  @default(none)
  pendingPayloadJson Json?
  pendingRequestedAt DateTime?
  // 온라인 예약 승인/거절/취소 시 오너가 남기는 사유(선택). 고객 조회 페이지에 노출. 마지막 결정 사유로 덮어씀.
  decisionReason   String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  pointHistories   CustomerPointHistory[]
  customer         Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee         Assignee?                 @relation(fields: [assigneeId], references: [id])
  store            Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  histories        ReservationHistory[]
  paymentEntries   ReservationPaymentEntry[]
  membershipUsages MembershipUsage[]
  couponsUsed      CustomerCoupon[]

  @@unique([storeId, legacyId])
  @@unique([storeId, naverBookingId])
  @@index([storeId, date])
}

model ReservationPaymentEntry {
  id            String        @id @default(cuid())
  reservationId String
  method        PaymentMethod
  amount        Int
  createdAt     DateTime      @default(now())
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ReservationHistory {
  id            String      @id @default(cuid())
  storeId       String
  reservationId String
  beforeJson    Json
  afterJson     Json
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StorePointSettings {
  id                String   @id @default(cuid())
  storeId           String   @unique
  enableServiceRate Boolean  @default(false)
  serviceRate       Int      @default(0)
  enableRecharge    Boolean  @default(false)
  rechargeRulesJson Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreBusinessHour {
  id        String   @id @default(cuid())
  storeId   String
  dayIndex  Int
  openTime  String
  closeTime String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayIndex])
}

model StoreClosedDate {
  id        String   @id @default(cuid())
  storeId   String
  date      DateTime
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
}

// 매장 공지사항(공개 예약 페이지 노출). 오너가 관리, visible=true만 고객에게 표시.
// title/body 다국어({en?,ja?,zh?}, 없으면 한국어 폴백). category: notice | event | info.
model StoreNotice {
  id            String   @id @default(cuid())
  storeId       String
  category      String   @default("notice")
  title         String
  titleI18nJson Json?
  body          String
  bodyI18nJson  Json?
  visible       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// 공개(고객) 온라인 예약 규칙. Store.useOnlineBooking ON일 때만 의미.
model StoreBookingSettings {
  id                  String   @id @default(cuid())
  storeId             String   @unique
  slotIntervalMin     Int      @default(30)
  minLeadMinutes      Int      @default(60)
  maxAdvanceDays      Int      @default(30)
  allowAssigneeChoice Boolean  @default(true)
  noticeText          String?
  // 공개 예약 페이지 안내문 다국어(오너 입력, {en?,ja?,zh?}). 없으면 noticeText 폴백.
  noticeI18nJson      Json?
  // 예약 상태별 오너 안내문구(#139). 각 텍스트 + 다국어({en?,ja?,zh?}). 없으면 미표시.
  //  done = 예약완료(신청 접수) 직후 화면, confirm = 조회 페이지 상태=확정, cancel = 조회 페이지 상태=취소.
  doneText            String?
  doneI18nJson        Json?
  confirmText         String?
  confirmI18nJson     Json?
  cancelText          String?
  cancelI18nJson      Json?
  // (1c) 공개 노출 서비스 화이트리스트(서비스명 배열). null/미지정 = 전체 노출. 배선은 1c.
  bookableServiceIdsJson Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Invite {
  id         String         @id @default(cuid())
  storeId    String
  code       String         @unique
  role       MembershipRole
  expiresAt  DateTime
  usedAt     DateTime?
  usedById   String?
  createdBy  String
  createdAt  DateTime       @default(now())
  store      Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  usedByUser User?          @relation("InviteUsedBy", fields: [usedById], references: [id])
  creator    User           @relation("InviteCreatedBy", fields: [createdBy], references: [id])
}

enum MembershipRole {
  owner
  manager
  staff
}

enum ReservationStatus {
  active
  completed
  cancelled
  noshow
  requested
}

enum PaymentMethod {
  cash
  cash_receipt
  card
  naver_pay
  local_currency
  local_currency_receipt
  voucher
  points
  discount
  naver_deposit
}

enum ReservationChannel {
  naver
  walk_in
  phone
  online
}

// 고객 변경/취소 요청(오너 승인형)의 대기 상태. 예약당 대기 요청 1건.
enum ReservationPendingAction {
  none
  cancel
  change
}

enum PointHistoryType {
  manual_add
  manual_subtract
  recharge
  payment_use
  payment_earn
  payment_adjust
}

model CustomerMergeHistory {
  id                   String   @id @default(cuid())
  storeId              String
  sourceCustomerJson   Json
  targetCustomerJson   Json
  movedReservationIds  Json     @default("[]")
  movedPointHistoryIds Json     @default("[]")
  addedMemoTagIds      Json     @default("[]")
  createdAt            DateTime @default(now())

  @@index([storeId])
}

model ConflictResolution {
  id          String   @id @default(cuid())
  storeId     String
  conflictKey String
  reason      String
  memo        String?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, conflictKey])
  @@index([storeId])
}

model Inquiry {
  id        String   @id @default(cuid())
  storeId   String?
  name      String
  email     String   @default("")
  content   String
  createdAt DateTime @default(now())
}

enum AssigneeStatus {
  active
  on_leave
  resigned
}

// ── 회원권(membership) — 횟수/기간권. 적립금(금액)과 별개. ───────────────
model MembershipProduct {
  id                   String                     @id @default(cuid())
  legacyId             Int?
  storeId              String
  name                 String
  totalCount           Int? // 횟수 (null=무제한/기간제)
  validDays            Int? // 발급일+유효일수 (null=무기한)
  price                Int                        @default(0)
  appliesToAllServices Boolean                    @default(true)
  status               String                     @default("active") // active | archived
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  store                Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  services             MembershipProductService[]
  issued               CustomerMembership[]

  @@unique([storeId, legacyId])
}

model MembershipProductService {
  id        String            @id @default(cuid())
  productId String
  serviceId String
  product   MembershipProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  service   Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([productId, serviceId])
}

model CustomerMembership {
  id             String             @id @default(cuid())
  legacyId       Int?
  storeId        String
  customerId     String
  productId      String?
  name           String // 발급 시점 상품명 스냅샷
  totalCount     Int?
  remainingCount Int?
  issuedAt       DateTime           @default(now())
  expiresAt      DateTime?
  status         String             @default("active") // active | expired | used_up | cancelled
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  store          Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product        MembershipProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  usages         MembershipUsage[]

  @@unique([storeId, legacyId])
}

model MembershipUsage {
  id                   String             @id @default(cuid())
  customerMembershipId String
  reservationId        String?
  delta                Int // 음수=차감, 양수=환불/발급
  type                 String // issue | use | adjust | refund
  memo                 String?
  createdAt            DateTime           @default(now())
  customerMembership   CustomerMembership @relation(fields: [customerMembershipId], references: [id], onDelete: Cascade)
  reservation          Reservation?       @relation(fields: [reservationId], references: [id], onDelete: SetNull)
}

model CouponProduct {
  id             String           @id @default(cuid())
  legacyId       Int?
  storeId        String
  name           String
  discountType   String // amount | rate
  discountValue  Int // 원(amount) 또는 %(rate)
  maxDiscount    Int? // 정률 상한 (null=무제한)
  minOrderAmount Int? // 최소 결제금액 (null=제한없음)
  validDays      Int? // 발급일+유효일수 (null=무기한)
  code           String? // 코드형이면 코드 (null=직접발급 전용)
  status         String           @default("active") // active | archived
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  store          Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  issued         CustomerCoupon[]

  @@unique([storeId, legacyId])
  @@unique([storeId, code])
}

model CustomerCoupon {
  id             String         @id @default(cuid())
  legacyId       Int?
  storeId        String
  customerId     String
  productId      String?
  name           String // 발급 시점 상품명 스냅샷
  discountType   String
  discountValue  Int
  maxDiscount    Int?
  minOrderAmount Int?
  issuedAt       DateTime       @default(now())
  expiresAt      DateTime?
  usedAt         DateTime?
  reservationId  String? // 사용한 예약(차감 시 기록)
  status         String         @default("active") // active | used | expired | cancelled
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product        CouponProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  reservation    Reservation?   @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@unique([storeId, legacyId])
}
