{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@prisma/client": [
        "./node_modules/@prisma/client"
      ],
      "@prisma/client/*": [
        "./node_modules/@prisma/client/*"
      ],
      "@prisma/adapter-pg": [
        "./node_modules/@prisma/adapter-pg"
      ],
      "nodemailer": [
        "./node_modules/@types/nodemailer",
        "./node_modules/nodemailer"
      ],
      "next": [
        "./node_modules/next"
      ],
      "next/*": [
        "./node_modules/next/*"
      ],
      "next-auth": [
        "./node_modules/next-auth"
      ],
      "next-auth/*": [
        "./node_modules/next-auth/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
