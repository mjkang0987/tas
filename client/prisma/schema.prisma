generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id                     String               @id @default(cuid())
  name                   String
  onboarded              Boolean              @default(false)
  categoryBaseColorsJson Json                 @default("{}")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  customers              Customer[]
  designers              Designer[]
  invites                Invite[]
  memberships            Membership[]
  reservations           Reservation[]
  reservationEvents      ReservationHistory[]
  services               Service[]
  businessHours          StoreBusinessHour[]
  closedDates            StoreClosedDate[]
  pointSettings          StorePointSettings?
}

model User {
  id              String        @id @default(cuid())
  email           String?       @unique
  nickname        String        @unique
  name            String?
  image           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        AuthAccount[]
  invitesUsed     Invite[]      @relation("InviteUsedBy")
  invitesCreated  Invite[]      @relation("InviteCreatedBy")
  memberships     Membership[]
}

model AuthAccount {
  id             String    @id @default(cuid())
  userId         String    @unique
  provider       String
  providerSub    String
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSub])
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  storeId   String
  role      MembershipRole
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Customer {
  id             String                 @id @default(cuid())
  legacyId       Int?
  storeId        String
  name           String
  tel            String
  points         Int                    @default(0)
  firstVisitDate DateTime?
  allergyNote    String?
  claimNote      String?
  preferenceNote String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  memoTags       CustomerMemoTag[]
  pointHistories CustomerPointHistory[]
  reservations   Reservation[]

  @@unique([storeId, legacyId])
  @@index([storeId, name])
  @@index([storeId, tel])
}

model CustomerMemoTag {
  id         String   @id @default(cuid())
  customerId String
  text       String
  color      String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerPointHistory {
  id                   String           @id @default(cuid())
  customerId           String
  type                 PointHistoryType
  delta                Int
  balance              Int
  description          String
  relatedReservationId String?
  createdAt            DateTime         @default(now())
  customer             Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  relatedReservation   Reservation?     @relation(fields: [relatedReservationId], references: [id])
}

model Designer {
  id           String             @id @default(cuid())
  legacyId     Int?
  storeId      String
  name         String
  status       DesignerStatus     @default(active)
  phone        String?
  note         String?
  color        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  schedules    DesignerSchedule[]
  reservations Reservation[]

  @@unique([storeId, legacyId])
}

model DesignerSchedule {
  id         String   @id @default(cuid())
  designerId String
  dayIndex   Int
  enabled    Boolean
  startTime  String
  endTime    String
  designer   Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)

  @@unique([designerId, dayIndex])
}

model Service {
  id         String   @id @default(cuid())
  legacyName String?
  storeId    String
  name       String
  category   String
  duration   Int
  price      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, name])
}

model Reservation {
  id               String                    @id @default(cuid())
  legacyId         Int?
  storeId          String
  customerId       String
  designerId       String?
  date             DateTime
  startTime        String
  endTime          String
  serviceSummary   String
  status           ReservationStatus         @default(active)
  price            Int                       @default(0)
  memo             String?
  paymentCompleted Boolean                   @default(false)
  pointEarned      Int                       @default(0)
  naverBookingId   String?
  naverBookingUrl  String?
  naverDeposit     Int?
  channel          ReservationChannel        @default(phone)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  pointHistories   CustomerPointHistory[]
  customer         Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  designer         Designer?                 @relation(fields: [designerId], references: [id])
  store            Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  histories        ReservationHistory[]
  paymentEntries   ReservationPaymentEntry[]

  @@unique([storeId, legacyId])
  @@unique([storeId, naverBookingId])
  @@index([storeId, date])
}

model ReservationPaymentEntry {
  id            String        @id @default(cuid())
  reservationId String
  method        PaymentMethod
  amount        Int
  createdAt     DateTime      @default(now())
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ReservationHistory {
  id            String      @id @default(cuid())
  storeId       String
  reservationId String
  beforeJson    Json
  afterJson     Json
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StorePointSettings {
  id                String   @id @default(cuid())
  storeId           String   @unique
  enableServiceRate Boolean  @default(false)
  serviceRate       Int      @default(0)
  enableRecharge    Boolean  @default(false)
  rechargeRulesJson Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreBusinessHour {
  id        String   @id @default(cuid())
  storeId   String
  dayIndex  Int
  openTime  String
  closeTime String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayIndex])
}

model StoreClosedDate {
  id        String   @id @default(cuid())
  storeId   String
  date      DateTime
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
}

model Invite {
  id        String         @id @default(cuid())
  storeId   String
  code      String         @unique
  role      MembershipRole
  expiresAt DateTime
  usedAt    DateTime?
  usedById  String?
  createdBy String
  createdAt DateTime       @default(now())
  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  usedByUser User?         @relation("InviteUsedBy", fields: [usedById], references: [id])
  creator   User           @relation("InviteCreatedBy", fields: [createdBy], references: [id])
}

enum MembershipRole {
  owner
  manager
  staff
}

enum ReservationStatus {
  active
  completed
  cancelled
  noshow
}

enum PaymentMethod {
  cash
  cash_receipt
  card
  naver_pay
  local_currency
  local_currency_receipt
  voucher
  points
  discount
  naver_deposit
}

enum ReservationChannel {
  naver
  walk_in
  phone
}

enum PointHistoryType {
  manual_add
  manual_subtract
  recharge
  payment_use
  payment_earn
  payment_adjust
}

model CustomerMergeHistory {
  id                    String   @id @default(cuid())
  storeId               String
  sourceCustomerJson    Json
  targetCustomerJson    Json
  movedReservationIds   Json     @default("[]")
  movedPointHistoryIds  Json     @default("[]")
  addedMemoTagIds       Json     @default("[]")
  createdAt             DateTime @default(now())

  @@index([storeId])
}

model Inquiry {
  id        String   @id @default(cuid())
  storeId   String?
  name      String
  email     String   @default("")
  content   String
  createdAt DateTime @default(now())
}

enum DesignerStatus {
  active
  on_leave
  resigned
}
